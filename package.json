{
  "name": "audience-builder",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w apps/api\" \"npm run dev -w apps/web\"",
    "build": "npm run build -w apps/api && npm run build -w apps/web",
    "seed": "npm run seed -w apps/api",
    "fetch:taxonomy": "npm run fetch:taxonomy -w apps/api",
    "prisma:migrate": "npm run prisma:migrate -w apps/api",
    "prisma:generate": "npm run prisma:generate -w apps/api"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@google/genai": "^2.6.0",
    "openai": "^6.39.0"
  }
}
